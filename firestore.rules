rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in [
          'xFWRzoBGgRc2UlBPKLW2fqMFsm13'
        ];
    }

    match /songs/{songId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /playlists/{playlistId} {
      allow read, write: if isAdmin();
    }
  }
}
